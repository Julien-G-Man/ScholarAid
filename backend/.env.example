# Django
SECRET_KEY=change-me

# Platform superuser (created/updated via: python manage.py ensure_superuser)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
FRONTEND_URL=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=31536000

# Database
# Leave DATABASE_URL empty to use SQLite in development.
# Example Postgres URL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=False

# AI Providers (Multi-Provider Orchestration)
# Priority order: Claude > NVIDIA DeepSeek > NVIDIA OpenAI > Azure > DeepSeek > Gemini > HuggingFace > Cohere

# Anthropic Claude
CLAUDE_API_KEY=your-claude-api-key

# NVIDIA API Endpoints
NVIDIA_DEEPSEEK_API_KEY=your-nvidia-deepseek-key
NVIDIA_OPENAI_API_KEY=your-nvidia-openai-key

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/

# DeepSeek Direct
DEEPSEEK_API_KEY=your-deepseek-key

# Google Gemini
GEMINI_API_KEY=your-gemini-key

# HuggingFace
HUGGINGFACE_API_KEY=your-huggingface-key

# Cohere
COHERE_API_KEY=your-cohere-key

